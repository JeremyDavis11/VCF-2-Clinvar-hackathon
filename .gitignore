# =============================================================================
# BIOHACK 2026 — .gitignore
# Python · Streamlit · pandas · Plotly
# =============================================================================

# --- Large / sensitive data files -------------------------------------------
data/raw/
data/processed/
data/clinvar_trimmed.csv
*.vcf
*.vcf.gz
*.bcf
*.tbi
*.bai

# --- Exceptions: demo data safe to commit ------------------------------------
!data/demo/demo.vcf

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# --- Virtual environments ----------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# --- Distribution / packaging ------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/

# --- Testing & coverage ------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Jupyter (in case anyone explores locally) -------------------------------
.ipynb_checkpoints/
*.ipynb

# --- Streamlit ---------------------------------------------------------------
.streamlit/secrets.toml

# --- Type checking & linting -------------------------------------------------
.mypy_cache/
.ruff_cache/

# --- pixi (conda env manager) ------------------------------------------------
.pixi/

# --- Results & outputs -------------------------------------------------------
results/

# --- OS clutter --------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Editors & IDEs ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs & temp files -------------------------------------------------------
*.log
*.tmp
*.bak

# --- Directory placeholders --------------------------------------------------
!.gitkeep# pixi environments
.pixi/*
!.pixi/config.toml
